<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <configSections>
    </configSections>
    <connectionStrings>
        <add name="DashBoard.My.MySettings.BANKConnectionString" connectionString="Provider=Microsoft.ACE.OLEDB.12.0;Data Source=Y:\SQL\BANK.accdb"
